# Backend Configuration
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///./data/umamimatch.db
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Frontend Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# AI Provider Configuration
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
OPENAI_MENU_MODEL=gpt-4o-mini
OPENAI_DECISION_MODEL=gpt-4o-mini
OPENAI_TIE_BREAK_MODEL=gpt-4o-mini
OPENAI_DECISION_TEMPERATURE=0.1
MENU_SCRAPER=openai
# OPENAI_API_KEY=your-openai-api-key

# Google Maps Platform Configuration
# Fast-and-dirty hackathon setup can use the same key for both frontend and backend.
# For production, split browser and server keys.
GOOGLE_MAPS_SERVER_API_KEY=your-google-maps-api-key

# Vertex AI Configuration (optional when LLM_PROVIDER=vertexai)
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=backend/app/secrets/your-credentials.json
