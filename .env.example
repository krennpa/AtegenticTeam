# Backend Configuration
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:////app/data/dynalunch.db
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Frontend Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Google Cloud Configuration (Required for AI decision agent)
# For local development (Windows):
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=app/secrets/your-credentials.json
# 
# For Docker (Linux), use absolute path - already set in docker-compose.yml:
# GOOGLE_APPLICATION_CREDENTIALS=/app/app/secrets/your-credentials.json
